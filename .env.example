# Grassmarket environment — copy to `.env` and fill. NEVER commit `.env` (git-ignored).
# All settings are read via src/grassmarket/config.py (pydantic-settings). Fail-loud:
# a missing required setting refuses to start rather than defaulting.

# --- Core ---
GM_ENV=local                       # local | ci | staging | production
GM_DEBUG=true

# --- Database ---
# Local dev / CI use SQLite by default (see config.py). Railway injects DATABASE_URL for Postgres.
# Example Postgres: postgresql+psycopg://user:password@host:5432/grassmarket
GM_DATABASE_URL=sqlite+pysqlite:///./local.db

# --- Auth / JWT (Holy Corner claim shape) ---
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
GM_JWT_SECRET=change-me-in-real-environments-use-a-48-byte-urlsafe-token
GM_JWT_ALGORITHM=HS256
GM_JWT_ACCESS_TTL_MINUTES=30
GM_JWT_ISSUER=advisors.bruntsfieldcapital.com
GM_JWT_AUDIENCE=bruntsfield

# --- Invitations ---
GM_INVITE_TTL_HOURS=168            # 7 days

# --- CORS (frontend origin) ---
GM_FRONTEND_ORIGIN=http://localhost:3000
