{
  "additionalProperties": false,
  "description": "One advisor's spaced-repetition state for a drill TOPIC (a power / triad / module / anchor).\nThe SM-2 fields (`repetitions`, `easiness`, `interval_days`) update on every review; `due_at` is\nwhen it next surfaces; `streak` is consecutive passes.",
  "properties": {
    "answer": {
      "default": "",
      "description": "The model answer (back of the card).",
      "title": "Answer",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "due_at": {
      "format": "date-time",
      "title": "Due At",
      "type": "string"
    },
    "easiness": {
      "default": 2.5,
      "minimum": 1.3,
      "title": "Easiness",
      "type": "number"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "interval_days": {
      "default": 0,
      "minimum": 0,
      "title": "Interval Days",
      "type": "integer"
    },
    "last_reviewed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Reviewed At"
    },
    "owner_consultant_id": {
      "description": "The consultant who owns this resource. Data scoping is by this field, enforced in the repository layer and tested from day one.",
      "format": "uuid",
      "title": "Owner Consultant Id",
      "type": "string"
    },
    "prompt": {
      "default": "",
      "description": "The recall question (front of the card).",
      "title": "Prompt",
      "type": "string"
    },
    "repetitions": {
      "default": 0,
      "minimum": 0,
      "title": "Repetitions",
      "type": "integer"
    },
    "streak": {
      "default": 0,
      "minimum": 0,
      "title": "Streak",
      "type": "integer"
    },
    "topic": {
      "description": "e.g. 'power:SCALE_ECONOMIES' or 'module:OEMS'.",
      "minLength": 1,
      "title": "Topic",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "id",
    "created_at",
    "updated_at",
    "owner_consultant_id",
    "topic",
    "due_at"
  ],
  "title": "DrillCard",
  "type": "object"
}
