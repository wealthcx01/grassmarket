{
  "$defs": {
    "WorkshopState": {
      "description": "A workshop is scheduled, then delivered (PRD §4). Recovery-fee attribution keys off the\ndelivered date + the config window; the window itself is NOT a per-workshop field (it is\nconfiguration — GRS-0012).",
      "enum": [
        "scheduled",
        "delivered"
      ],
      "title": "WorkshopState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "A workshop in a consultant's pipeline, linked to a prospect (PRD §4).",
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "delivered_on": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Delivered On"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "owner_consultant_id": {
      "description": "The consultant who owns this resource. Data scoping is by this field, enforced in the repository layer and tested from day one.",
      "format": "uuid",
      "title": "Owner Consultant Id",
      "type": "string"
    },
    "pre_workshop_brief": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pre Workshop Brief"
    },
    "prospect_id": {
      "format": "uuid",
      "title": "Prospect Id",
      "type": "string"
    },
    "scheduled_for": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scheduled For"
    },
    "state": {
      "$ref": "#/$defs/WorkshopState",
      "default": "scheduled"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "workshop_output": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Workshop Output"
    }
  },
  "required": [
    "id",
    "created_at",
    "updated_at",
    "owner_consultant_id",
    "prospect_id"
  ],
  "title": "Workshop",
  "type": "object"
}
