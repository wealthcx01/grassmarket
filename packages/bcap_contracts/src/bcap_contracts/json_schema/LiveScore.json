{
  "$defs": {
    "IndexBand": {
      "additionalProperties": false,
      "description": "A P10/P50/P90 band for one index with the ADR-0008 honesty flag. `modelled = False` ⟹ a\npoint estimate (P10=P50=P90) — the client shows a point labelled 'uncertainty not modelled',\nnever a tight band.",
      "properties": {
        "modelled": {
          "title": "Modelled",
          "type": "boolean"
        },
        "p10": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "P10",
          "type": "number"
        },
        "p50": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "P50",
          "type": "number"
        },
        "p90": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "P90",
          "type": "number"
        }
      },
      "required": [
        "p10",
        "p50",
        "p90",
        "modelled"
      ],
      "title": "IndexBand",
      "type": "object"
    },
    "StrengthRating": {
      "description": "Power strength and triad rating — ordinal with falsifiable duration semantics (§8).\n\nReported as a rating, NEVER as a decimal. Establishing this as an enum (not a float) is the\nADR-0002 guarantee that no decimal leaks into a triad figure.",
      "enum": [
        "None",
        "Emerging",
        "Established",
        "Wide"
      ],
      "title": "StrengthRating",
      "type": "string"
    },
    "UncertaintyRating": {
      "description": "Assessment Uncertainty Rating (Methodology §7), Morningstar pattern.",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Very High"
      ],
      "title": "UncertaintyRating",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "The live-score panel output for a (possibly partial) document. When `scoreable`, the bands\nare present; else `blocking` says what is still needed. Not Assessed inputs flow through as\nfirst-class (excluded, never zero) and are reflected in `coverage`.",
  "properties": {
    "b": {
      "anyOf": [
        {
          "$ref": "#/$defs/IndexBand"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "b_point": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "B Point"
    },
    "blocking": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Blocking",
      "type": "array"
    },
    "c": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "C"
    },
    "coefficient_version": {
      "title": "Coefficient Version",
      "type": "string"
    },
    "coverage": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Coverage"
    },
    "engine_version": {
      "title": "Engine Version",
      "type": "string"
    },
    "l_index": {
      "anyOf": [
        {
          "$ref": "#/$defs/IndexBand"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "l_point": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "L Point"
    },
    "methodology_version": {
      "title": "Methodology Version",
      "type": "string"
    },
    "module_qm": {
      "additionalProperties": {
        "$ref": "#/$defs/IndexBand"
      },
      "title": "Module Qm",
      "type": "object"
    },
    "module_weights": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Module Weights",
      "type": "object"
    },
    "overall_uncertainty": {
      "anyOf": [
        {
          "$ref": "#/$defs/UncertaintyRating"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "p": {
      "anyOf": [
        {
          "$ref": "#/$defs/IndexBand"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "p_point": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "P Point"
    },
    "scoreable": {
      "title": "Scoreable",
      "type": "boolean"
    },
    "subcomponents_assessed": {
      "default": 0,
      "title": "Subcomponents Assessed",
      "type": "integer"
    },
    "subcomponents_total": {
      "default": 0,
      "title": "Subcomponents Total",
      "type": "integer"
    },
    "theta_b": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Theta B"
    },
    "theta_l": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Theta L"
    },
    "theta_p": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Theta P"
    },
    "triad_defence": {
      "anyOf": [
        {
          "$ref": "#/$defs/StrengthRating"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "triad_economic": {
      "anyOf": [
        {
          "$ref": "#/$defs/StrengthRating"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "triad_perceived": {
      "anyOf": [
        {
          "$ref": "#/$defs/StrengthRating"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "uncertainty_version": {
      "title": "Uncertainty Version",
      "type": "string"
    },
    "v": {
      "anyOf": [
        {
          "$ref": "#/$defs/IndexBand"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "v_point": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "V Point"
    }
  },
  "required": [
    "scoreable",
    "engine_version",
    "methodology_version",
    "coefficient_version",
    "uncertainty_version"
  ],
  "title": "LiveScore",
  "type": "object"
}
