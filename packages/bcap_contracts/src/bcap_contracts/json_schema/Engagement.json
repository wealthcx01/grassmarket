{
  "$defs": {
    "EngagementStatus": {
      "enum": [
        "scoped",
        "contracted",
        "active",
        "delivered",
        "closed"
      ],
      "title": "EngagementStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "owner_consultant_id": {
      "description": "The consultant who owns this resource. Data scoping is by this field, enforced in the repository layer and tested from day one.",
      "format": "uuid",
      "title": "Owner Consultant Id",
      "type": "string"
    },
    "prospect_id": {
      "format": "uuid",
      "title": "Prospect Id",
      "type": "string"
    },
    "started_on": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started On"
    },
    "status": {
      "$ref": "#/$defs/EngagementStatus",
      "default": "scoped"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "id",
    "created_at",
    "updated_at",
    "owner_consultant_id",
    "prospect_id",
    "title"
  ],
  "title": "Engagement",
  "type": "object"
}
