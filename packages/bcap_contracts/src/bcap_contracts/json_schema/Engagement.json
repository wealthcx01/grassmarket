{
  "$defs": {
    "CommsChannel": {
      "enum": [
        "note",
        "email",
        "call",
        "meeting"
      ],
      "title": "CommsChannel",
      "type": "string"
    },
    "CommsLogEntry": {
      "additionalProperties": false,
      "description": "One timestamped communication-log entry. Append-only in practice (the repository never\nupdates one); ordering is by ``at``.",
      "properties": {
        "at": {
          "format": "date-time",
          "title": "At",
          "type": "string"
        },
        "author_consultant_id": {
          "format": "uuid",
          "title": "Author Consultant Id",
          "type": "string"
        },
        "body": {
          "minLength": 1,
          "title": "Body",
          "type": "string"
        },
        "channel": {
          "$ref": "#/$defs/CommsChannel"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "at",
        "channel",
        "author_consultant_id",
        "body"
      ],
      "title": "CommsLogEntry",
      "type": "object"
    },
    "DeliverableSlot": {
      "additionalProperties": false,
      "description": "A placeholder for one deliverable's progress. The Loop 4 builder fills the content; here we\ncarry only a key + a status so the engagement can track progress before the builder exists.",
      "properties": {
        "key": {
          "description": "Deliverable identifier the Loop 4 builder owns.",
          "minLength": 1,
          "title": "Key",
          "type": "string"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "status": {
          "$ref": "#/$defs/DeliverableStatus",
          "default": "not_started"
        }
      },
      "required": [
        "key"
      ],
      "title": "DeliverableSlot",
      "type": "object"
    },
    "DeliverableStatus": {
      "description": "Progress of one deliverable slot. Deliverable *content* is Loop 4 (the builder); this is the\nforward-compatible progress shell only — a closed status set, no fabricated content.",
      "enum": [
        "not_started",
        "in_progress",
        "drafted",
        "delivered"
      ],
      "title": "DeliverableStatus",
      "type": "string"
    },
    "EngagementStatus": {
      "enum": [
        "scoped",
        "contracted",
        "active",
        "delivered",
        "closed"
      ],
      "title": "EngagementStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "A contracted prospect's delivery record: which assessment(s) it draws on, a deliverables\nprogress shell (Loop 4 fills content), and a communication log (PRD §4).",
  "properties": {
    "assessment_ids": {
      "default": [],
      "description": "Finalised assessments this engagement draws on (GRS-0009).",
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Assessment Ids",
      "type": "array"
    },
    "comms_log": {
      "default": [],
      "items": {
        "$ref": "#/$defs/CommsLogEntry"
      },
      "title": "Comms Log",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "deliverables": {
      "default": [],
      "items": {
        "$ref": "#/$defs/DeliverableSlot"
      },
      "title": "Deliverables",
      "type": "array"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "owner_consultant_id": {
      "description": "The consultant who owns this resource. Data scoping is by this field, enforced in the repository layer and tested from day one.",
      "format": "uuid",
      "title": "Owner Consultant Id",
      "type": "string"
    },
    "prospect_id": {
      "format": "uuid",
      "title": "Prospect Id",
      "type": "string"
    },
    "started_on": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started On"
    },
    "status": {
      "$ref": "#/$defs/EngagementStatus",
      "default": "scoped"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "id",
    "created_at",
    "updated_at",
    "owner_consultant_id",
    "prospect_id",
    "title"
  ],
  "title": "Engagement",
  "type": "object"
}
